  "data_management_label": "Pengurusan Data:",
  "data_management_desc": "Menyimpan, membuat sandaran, dan melindungi data (sama ada secara tempatan atau antarabangsa) untuk kesinambungan operasi dan pemulihan bencana.",
  "legal_disclosure_label": "Pendedahan Undang-undang:",
